# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# SurrealDB Configuration
SURREAL_ADDR=ws://127.0.0.1:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=notebook
SURREAL_DB=main

# Authentication
JWT_SECRET=dev-secret-change-me
JWT_EXPIRATION_HOURS=24

# LLM Configuration (Gemini) — same key is used for completion and embedding
# Use LLM_API_KEY or GEMINI_API_KEY (Google docs often use GEMINI_API_KEY)
LLM_API_KEY=your-google-ai-api-key
# GEMINI_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=4096

# Embedding: Google Gemini embedding model (same API key as above)
# Use embedding-001 (v1beta); text-embedding-004 may return 404 on this API.
EMBEDDING_MODEL=embedding-001

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
