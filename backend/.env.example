# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# SurrealDB
SURREAL_ADDR=ws://127.0.0.1:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=notebook
SURREAL_DB=main

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# LLM - OpenAI Compatible
LLM_API_KEY=sk-your-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
