# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# SurrealDB Configuration
SURREAL_ADDR=ws://127.0.0.1:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=notebook
SURREAL_DB=main

# Authentication
JWT_SECRET=dev-secret-change-me
JWT_EXPIRATION_HOURS=24

# LLM Configuration
# Supported providers: gemini, openai, anthropic, deepseek, openai_compatible
LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key
# GEMINI_API_KEY=your-google-ai-api-key       # fallback if LLM_API_KEY not set
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=4096
# LLM_BASE_URL=https://custom-api.example.com  # optional: override provider's default URL

# Embedding Configuration (defaults to main LLM provider if not set)
EMBEDDING_MODEL=embedding-001
# EMBEDDING_PROVIDER=openai                    # optional: use a different provider for embeddings
# EMBEDDING_API_KEY=sk-...                     # optional: separate API key for embeddings
# EMBEDDING_BASE_URL=https://api.openai.com/v1 # optional: custom embedding endpoint

# ─── Provider Examples ───
# Gemini (default):
#   LLM_PROVIDER=gemini  LLM_API_KEY=AIza...  LLM_MODEL=gemini-2.0-flash
# OpenAI:
#   LLM_PROVIDER=openai  LLM_API_KEY=sk-...   LLM_MODEL=gpt-4o
# Anthropic:
#   LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-...  LLM_MODEL=claude-sonnet-4-20250514
# DeepSeek:
#   LLM_PROVIDER=deepseek  LLM_API_KEY=sk-...  LLM_MODEL=deepseek-chat
# OpenAI-compatible (custom base URL, e.g. vLLM / LiteLLM / Ollama):
#   LLM_PROVIDER=openai_compatible  LLM_API_KEY=dummy  LLM_MODEL=llama3
#   LLM_BASE_URL=http://localhost:8000/v1

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
